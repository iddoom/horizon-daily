{
  "version": "1.0",
  "ai": {
    "provider": "anthropic",
    "model": "glm-5.2",
    "api_key_env": "ANTHROPIC_AUTH_TOKEN",
    "base_url": "https://open.bigmodel.cn/api/anthropic",
    "temperature": 0.3,
    "max_tokens": 4096,
    "throttle_sec": 1.5,
    "languages": [
      "zh",
      "en"
    ],
    "analysis_concurrency": 1,
    "enrichment_concurrency": 1
  },
  "sources": {
    "github": [
      {
        "type": "repo_releases",
        "owner": "openai",
        "repo": "openai-python",
        "enabled": true,
        "category": "ai-tools"
      },
      {
        "type": "repo_releases",
        "owner": "astral-sh",
        "repo": "uv",
        "enabled": true,
        "category": "it-devtools"
      }
    ],
    "hackernews": {
      "enabled": true,
      "fetch_top_stories": 25,
      "min_score": 120
    },
    "rss": [
      {
        "name": "Simon Willison",
        "url": "https://simonwillison.net/atom/everything/",
        "enabled": true,
        "category": "ai-thinking"
      },
      {
        "name": "OpenAI Blog",
        "url": "https://openai.com/news/rss.xml",
        "enabled": true,
        "category": "ai-news"
      },
      {
        "name": "Google AI Blog",
        "url": "https://blog.google/technology/ai/rss/",
        "enabled": true,
        "category": "ai-news"
      },
      {
        "name": "MIT Technology Review",
        "url": "https://www.technologyreview.com/feed/",
        "enabled": true,
        "category": "tech-thinking"
      },
      {
        "name": "TechCrunch",
        "url": "https://techcrunch.com/feed/",
        "enabled": true,
        "category": "it-business"
      },
      {
        "name": "The Verge",
        "url": "https://www.theverge.com/rss/index.xml",
        "enabled": true,
        "category": "digital-tech"
      },
      {
        "name": "IT之家",
        "url": "https://www.ithome.com/rss/",
        "enabled": true,
        "category": "digital-tech-cn"
      },
      {
        "name": "BBC World",
        "url": "https://feeds.bbci.co.uk/news/world/rss.xml",
        "enabled": true,
        "category": "world-news"
      },
      {
        "name": "Al Jazeera",
        "url": "https://www.aljazeera.com/xml/rss/all.xml",
        "enabled": true,
        "category": "world-news"
      }
    ],
    "reddit": {
      "enabled": false,
      "subreddits": [],
      "users": [],
      "fetch_comments": 5
    },
    "telegram": {
      "enabled": false,
      "channels": []
    },
    "twitter": {
      "enabled": false,
      "users": [
        "karpathy",
        "sama",
        "ylecun"
      ],
      "fetch_limit": 10,
      "fetch_reply_text": false,
      "max_replies_per_tweet": 3,
      "max_tweets_to_expand": 10,
      "reply_min_likes": 5
    },
    "ossinsight": {
      "enabled": true,
      "period": "past_24_hours",
      "languages": [
        "All",
        "Python",
        "TypeScript"
      ],
      "keywords": [
        "ai",
        "agent",
        "llm",
        "automation",
        "browser",
        "coding"
      ],
      "min_stars": 20,
      "max_items": 20
    }
  },
  "filtering": {
    "ai_score_threshold": 7.0,
    "time_window_hours": 24,
    "max_items": 18,
    "category_groups": {
      "ai": {
        "name": "AI / Agent / Automation",
        "limit": 6,
        "categories": [
          "ai-news",
          "ai-tools",
          "ai-thinking"
        ]
      },
      "it_digital": {
        "name": "IT / Digital Products",
        "limit": 4,
        "categories": [
          "it-devtools",
          "it-business",
          "digital-tech",
          "digital-tech-cn",
          "tech-thinking"
        ]
      },
      "world": {
        "name": "World Affairs / Geopolitics",
        "limit": 4,
        "categories": [
          "world-news",
          "world-china"
        ]
      },
      "github": {
        "name": "High-signal GitHub Projects",
        "limit": 4,
        "categories": [
          "oss",
          "developer-tools"
        ]
      }
    },
    "default_group": "other",
    "default_group_limit": 2
  },
  "webhook": {
    "enabled": false,
    "url_env": "HORIZON_WEBHOOK_URL",
    "delivery": "summary",
    "overview_position": "first",
    "platform": "generic",
    "layout": "markdown",
    "fallback_layout": "markdown",
    "languages": [
      "zh"
    ],
    "request_body": {
      "text": "Horizon #{date}\\n\\n#{summary}"
    },
    "headers": ""
  }
}
